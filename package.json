{
  "name": "@seriousme/opifex",
  "version": "1.11.3",
  "description": "MQTT client & server for Deno & NodeJS and Bun",
  "author": "Hans Klunder",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/seriousme/opifex.git"
  },
  "bugs": {
    "url": "https://github.com/seriousme/opifex/issues"
  },
  "homepage": "https://github.com/seriousme/opifex#readme",
  "keywords": [
    "MQTT",
    "typescript",
    "mqtt-broker"
  ],
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "bin": {
    "mqtt": "dist/bin/mqtt.js",
    "demoServer": "dist/bin/demoServer.js"
  },
  "scripts": {
    "test": "node  --test --test-skip-pattern='^(?:Deno|Web):'",
    "build": "rm -rf dist && npx -p typescript tsc --build",
    "format": "deno fmt",
    "coverage": "deno test -A . --coverage --clean --coverage-raw-data-only && deno coverage --exclude=.config --exclude=dev_utils --html",
    "preversion": "npm run test"
  },
  "files": [
    "package.json",
    "README.md",
    "LICENSE.txt",
    "**/*.ts",
    "dist/**/*.js",
    "dist/**/*.js.map",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map"
  ],
  "exports": {
    "./tcpClient": {
      "deno": "./deno/tcpClient.ts",
      "default": "./dist/node/tcpClient.js"
    },
    "./wsClient": {
      "deno": "./web/wsClient.ts",
      "browser": "./dist/web/wsClient.ts",
      "default": null
    },
    "./tcpServer": {
      "deno": "./deno/tcpServer.ts",
      "default": "./dist/node/tcpServer.js"
    },
    "./tlsServer": {
      "deno": "./deno/tlsServer.ts",
      "default": "./dist/node/tlsServer.js"
    },
    "./wsServer": {
      "deno": "./deno/wsServer.ts",
      "default": null
    },
    "./server": {
      "deno": "./server/mod.ts",
      "default": "./dist/server/mod.js"
    },
    "./client": {
      "deno": "./client/mod.ts",
      "default": "./dist/client/mod.js"
    },
    "./trie": {
      "deno": "./trie/trie.ts",
      "default": "./dist/trie/trie.js"
    },
    "./persistence": {
      "deno": "./persistence/mod.ts",
      "default": "./dist/persistence/mod.js"
    },
    "./mqttConn": {
      "deno": "./mqttConn/mqttConn.ts",
      "default": "./dist/mqttConn/mqttConn.js"
    },
    "./mqttPacket": {
      "deno": "./mqttPacket/mod.ts",
      "default": "./dist/mqttPacket/mod.js"
    },
    "./utils": {
      "deno": "./utils/mod.ts",
      "default": "./dist/utils/mod.js"
    }
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "@types/node-forge": "^1.3.14",
    "node-forge": "^1.4.0"
  }
}
